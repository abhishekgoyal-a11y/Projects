{
  "manifest_version": 3,
  "name": "LinkedIn Feed Scraper",
  "version": "1.0.0",
  "description": "Automates LinkedIn feed scrolling and scrapes posts (author, text, URLs) for personal export to JSON/CSV.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinkedIn Feed Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/search/results/*",
        "https://www.linkedin.com/feed/*",
        "https://www.linkedin.com/feed"
      ],
      "js": [
        "utils/helpers.js",
        "content/scraper.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["utils/*.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
